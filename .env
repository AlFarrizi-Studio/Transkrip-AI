# ==============================
# OpenRouter API
# ==============================
OPENROUTER_API_KEY=sk-or-v1-isi_key_kamu_disini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Attribution opsional untuk OpenRouter.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=OpenRouter 5AI Transcriber Explainer

# ==============================
# STT / Transcription
# ==============================
# Catatan: model transcription gratis di OpenRouter belum tentu tersedia di akun kamu.
# Kalau STT OpenRouter gagal, kamu tetap bisa paste transkrip manual ke textarea lalu klik analisis 5 AI.
OPENROUTER_STT_MODEL=openai/whisper-large-v3-turbo
DEFAULT_LANGUAGE=id
TRANSCRIBE_CHUNK_MS=8000

# ==============================
# 5 AI Agents untuk menjelaskan makna poin transkrip
# Total request saat klik analisis: 5 request
# 1) Qwen: ambil poin penting
# 2) GPT-OSS: jelaskan makna dan maksud
# 3) Gemma: konteks, istilah, ambiguitas
# 4) Llama: ringkas bahasa natural
# 5) Nemotron Ultra: final merger + validasi
# ==============================
AI1_EXTRACTOR_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
AI2_MEANING_MODEL=openai/gpt-oss-120b:free
AI3_CONTEXT_MODEL=google/gemma-4-31b-it:free
AI4_SUMMARY_MODEL=meta-llama/llama-3.3-70b-instruct:free
AI5_FINAL_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Fallback kalau salah satu model limit/error.
OPENROUTER_FALLBACK_MODEL=openrouter/free

# Token output. Naikkan kalau transkrip panjang.
AGENT_MAX_TOKENS=1100
FINAL_MAX_TOKENS=1800

PORT=3000
